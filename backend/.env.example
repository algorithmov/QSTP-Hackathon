# --- Stars of Science v2 Backend ---
# Copy to .env and fill in your keys.

# Set to true for zero-API-key demo mode (rule-based fallbacks, no LLM calls)
MOCK_MODE=true

# Groq LLM (get a free key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Tavily evidence search (optional — leave blank to use fallback_evidence.json)
TAVILY_API_KEY=
EVIDENCE_CACHE_TTL_HOURS=24

# CORS — must match your frontend dev URL
ALLOWED_ORIGINS=http://localhost:3000
