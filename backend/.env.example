# --- Stars of Science v3 Backend ---
# Copy to .env and fill in your keys.

# Set to true for zero-API-key demo mode (rule-based fallbacks, no LLM calls)
MOCK_MODE=true

# LLM provider order. Gemini is primary; Groq is kept as fallback.
LLM_PROVIDER_ORDER=gemini,groq

# Gemini LLM. Put one or more comma-separated keys for key rotation.
# Also used for multimodal media analysis (image/video/audio).
GEMINI_API_KEYS=
GEMINI_MODEL=gemini-2.5-flash

# Groq LLM fallback (get a free key at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Tavily/Serper evidence search (optional — leave blank to use seed data only)
TAVILY_API_KEY=
SERPER_API_KEY=
EVIDENCE_CACHE_TTL_HOURS=24

# CORS — must match your frontend dev URL
ALLOWED_ORIGINS=http://localhost:3000

# --- Local data directories (auto-created, gitignored) ---
# Drop scraped JSON/CSV files here and POST /api/admin/import to load them:
#   backend/data/imports/
# Uploaded review media is stored here:
#   backend/data/media/
